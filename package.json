{
  "name": "anomopi",
  "version": "1.0.1",
  "description": "es6",
  "private": true,
  "scripts": {
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --forceExit && python3 -m pytest src/back/util/myuzip_test.py src/back/util/twse_test.py -v",
    "build": "webpack --config config/webpack.release.config.cjs",
    "dev-test": "docker exec -w /app reactnode-server npm run test",
    "dev-test-int": "docker exec -w /app reactnode-server npm run test:integration",
    "dev-build": "docker exec -w /app reactnode-server npm run build",
    "dev-back": "docker compose -f docker-compose.dev.yml down; docker compose -f docker-compose.dev.yml up -d --build",
    "dev-code": "docker compose -f docker-compose.dev.yml restart reactnode-file-server reactnode-server nginx",
    "dev-front": "docker exec -w /app reactnode-server ./node_modules/.bin/webpack --watch --config config/webpack.dev.config.cjs",
    "dev-stop": "docker compose -f docker-compose.dev.yml down",
    "release": "docker compose -f docker-compose.release.yml up -d",
    "release-restart": "docker compose -f docker-compose.release.yml restart",
    "release-stop": "docker compose -f docker-compose.release.yml down",
    "postinstall": "patch-package",
    "test:integration": "NODE_OPTIONS=--experimental-vm-modules jest --forceExit --testPathPattern=\\.integration\\.test\\.js$",
    "test:smoke": "NODE_OPTIONS=--experimental-vm-modules jest --config jest.smoke.cjs --forceExit",
    "test:front": "jest --config jest.front.cjs --forceExit",
    "test:front:watch": "jest --config jest.front.cjs --watch",
    "test:front:coverage": "jest --config jest.front.cjs --forceExit --coverage",
    "dev-test-smoke": "docker exec -w /app -e NODE_OPTIONS=--experimental-vm-modules reactnode-file-server npx jest --config jest.smoke.cjs --forceExit --no-cache",
    "dev-test-front": "docker exec -w /app reactnode-server npm run test:front",
    "test:e2e": "npx playwright test --config e2e/playwright.config.js",
    "test:e2e:headed": "npx playwright test --config e2e/playwright.config.js --headed",
    "test:e2e:debug": "npx playwright test --config e2e/playwright.config.js --debug",
    "dev-test-e2e": "docker compose -f docker-compose.dev.yml run --rm e2e"
  },
  "type": "module",
  "dependencies": {
    "@babel/core": "^7.12.10",
    "@babel/plugin-proposal-class-properties": "^7.12.1",
    "@babel/plugin-transform-runtime": "^7.12.10",
    "@babel/preset-env": "^7.12.10",
    "@babel/preset-react": "^7.12.10",
    "@babel/runtime": "^7.12.5",
    "ass-to-vtt": "^1.2.0",
    "babel-loader": "^8.2.2",
    "bitfinex-api-node": "^4.0.16",
    "body-parser": "^1.19.0",
    "chart.js": "^2.9.4",
    "connect-multiparty": "^2.2.0",
    "connect-redis": "^5.0.0",
    "connected-react-router": "^6.8.0",
    "css-loader": "^5.0.1",
    "discord.js": "^12.5.1",
    "express": "^4.7.1",
    "express-session": "^1.17.1",
    "ffmpeg": "^0.0.4",
    "file-loader": "^6.2.0",
    "googleapis": "^66.0.0",
    "htmlparser2": "^5.0.1",
    "iconv-lite": "^0.6.2",
    "isomorphic-fetch": "^3.0.0",
    "jschardet": "^3.0.0",
    "mini-css-extract-plugin": "^1.3.3",
    "mkdirp": "^1.0.4",
    "mobile-detect": "^1.4.4",
    "mongodb": "^3.6.3",
    "node-fetch": "^2.6.1",
    "node-opencc": "^2.0.1",
    "opensubtitles-api": "^5.1.2",
    "opensubtitles.com": "^1.0.0",
    "passport": "^0.4.1",
    "passport-local": "^1.0.0",
    "password-generator": "^2.3.2",
    "pdfjs-dist": "^2.5.207",
    "react": "^17.0.1",
    "react-dom": "^17.0.1",
    "react-redux": "^7.2.2",
    "react-router-dom": "^5.2.0",
    "read-torrent": "^1.3.1",
    "redis": "^3.0.2",
    "redux": "^4.0.5",
    "torrent-stream": "^1.2.1",
    "url-loader": "^4.1.1",
    "utf8": "^3.0.0",
    "webpack": "^5.10.1",
    "webpack-cli": "^4.2.0",
    "ws": "^7.4.1",
    "xml2js": "^0.4.23",
    "yahoo-finance2": "^2.12.4",
    "youtube-dl-exec": "^2.4.7"
  },
  "author": {
    "name": "hoder",
    "emial": "hoder3388@gmail.com"
  },
  "devDependencies": {
    "@playwright/test": "^1.29.2",
    "@testing-library/dom": "^9.3.4",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^12.1.5",
    "@testing-library/user-event": "^14.6.1",
    "babel-jest": "^27.5.1",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^27.5.1",
    "jest-environment-jsdom": "^27.5.1",
    "patch-package": "^8.0.1",
    "supertest": "^7.2.2"
  }
}
